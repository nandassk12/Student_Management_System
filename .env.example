# ──────────────────────────────────────────────────────────────────────────────
# Student Management System - Environment Variable Example File
# Copy this file to '.env' and modify values accordingly for local runtime.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database Connection ───────────────────────────────────────────────────────
# Default values for local docker-compose configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/student_db

# ── JWT Authentication / Security ─────────────────────────────────────────────
# IMPORTANT: Change SECRET_KEY to a secure random hash in production!
SECRET_KEY=super-secret-cryptographic-hash-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── PostgreSQL Container Config (Docker Compose) ──────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=student_db
